---
import MainLayout from '@layouts/MainLayout.astro';
import { getActiveTreatments } from '@lib/queries';

let treatments = [];
let errorMsg = '';

try {
  treatments = await getActiveTreatments();
} catch (err) {
  errorMsg = err instanceof Error ? err.message : 'Error al cargar tratamientos';
}
---

<MainLayout title="Monitoreo en Vivo" subtitle="Seleccionar tratamiento para monitorear">
  {errorMsg && (
    <div class="mb-6 rounded-xl border border-red-200/60 bg-red-50/80 px-4 py-3 text-sm text-red-700 backdrop-blur-sm">
      {errorMsg}
    </div>
  )}
  {treatments.length === 0 && !errorMsg ? (
    <div class="flex flex-col items-center justify-center rounded-xl border-2 border-dashed border-gray-300 py-16">
      <p class="text-lg font-medium text-gray-500">No hay tratamientos activos para monitorear</p>
    </div>
  ) : (
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
      {treatments.map((t) => (
        <a
          href={`/monitoring/${t.id}`}
          class="group rounded-xl border border-gray-200 bg-white p-5 transition-all hover:border-radix-300 hover:shadow-card-hover"
        >
          <div class="mb-3 flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-radix-100">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-radix-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
              </svg>
            </div>
            <div>
              <p class="font-medium text-gray-900 group-hover:text-radix-700">
                {t.Patient?.name ?? 'Paciente'}
              </p>
              <p class="text-sm text-gray-500">{t.Radioisotope?.name ?? 'Isotopo'}</p>
            </div>
          </div>
          <div class="flex items-center justify-between text-xs text-gray-400">
            <span>Tratamiento #{t.id}</span>
            <span class="rounded-full bg-green-100 px-2 py-0.5 text-green-700">ACTIVO</span>
          </div>
        </a>
      ))}
    </div>
  )}
</MainLayout>
