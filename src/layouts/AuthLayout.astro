---
import '@styles/global.css';

interface Props {
  pageTitle?: string;
}

const { pageTitle = 'Login' } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="RADIX - Acceso al Panel Medico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle} | RADIX</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="relative flex min-h-screen items-center justify-center overflow-hidden bg-[#0a0814] font-sans antialiased">

    <!-- Dot grid -->
    <div class="pointer-events-none absolute inset-0 bg-dot-grid-dark"></div>

    <!-- Radial glow — top center -->
    <div class="pointer-events-none absolute left-1/2 top-0 h-[480px] w-[680px] -translate-x-1/2 -translate-y-1/3 rounded-full bg-radix-700/20 blur-[100px]"></div>

    <!-- Accent orbs -->
    <div class="pointer-events-none absolute -left-24 top-1/4 h-72 w-72 animate-float-slow rounded-full bg-radix-600/12 blur-3xl"></div>
    <div class="pointer-events-none absolute -right-24 bottom-1/4 h-64 w-64 animate-float-reverse rounded-full bg-radix-500/8 blur-3xl"></div>

    <!-- Horizontal scan line accent -->
    <div class="pointer-events-none absolute inset-x-0 top-1/2 h-px bg-gradient-to-r from-transparent via-radix-500/20 to-transparent"></div>

    <!-- Main Content -->
    <div class="relative z-10 w-full max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-20">

        <!-- Branding side (desktop only) -->
        <div class="hidden flex-col justify-center animate-fade-in lg:flex">

          <!-- Logo mark -->
          <div class="mb-8 flex items-center gap-4">
            <div class="relative flex h-14 w-14 items-center justify-center rounded-2xl bg-radix-600/20 ring-1 ring-radix-500/30">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-radix-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
                <circle cx="12" cy="12" r="3" />
                <line x1="12" y1="2" x2="12" y2="6" />
                <line x1="12" y1="18" x2="12" y2="22" />
                <line x1="2" y1="12" x2="6" y2="12" />
                <line x1="18" y1="12" x2="22" y2="12" />
              </svg>
              <!-- Glow ring -->
              <div class="absolute inset-0 rounded-2xl ring-1 ring-radix-400/20 animate-pulse-glow"></div>
            </div>
            <div>
              <p class="font-display text-[11px] font-semibold uppercase tracking-[0.2em] text-radix-400">Sistema Médico</p>
            </div>
          </div>

          <h1 class="font-display text-[56px] font-bold leading-none tracking-tight text-white xl:text-[68px]">
            RADIX
          </h1>
          <p class="mt-3 text-lg font-light leading-relaxed text-white/50">
            Panel de Monitoreo de<br/>Aislamiento Domiciliario
          </p>

          <!-- Feature pills -->
          <div class="mt-10 flex flex-wrap gap-3">
            {[
              { icon: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z', label: 'Acceso seguro' },
              { icon: 'M22 12h-4l-3 9L9 3l-3 9H2', label: 'Métricas en vivo' },
              { icon: 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z', label: 'Aislamiento domiciliario' },
            ].map(f => (
              <div class="flex items-center gap-2 rounded-full border border-white/8 bg-white/5 px-3 py-1.5 text-xs font-medium text-white/50 backdrop-blur-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-radix-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d={f.icon} />
                </svg>
                {f.label}
              </div>
            ))}
          </div>

          <!-- Divider -->
          <div class="mt-10 h-px w-24 bg-gradient-to-r from-radix-500/40 to-transparent"></div>
          <p class="mt-4 font-mono text-[11px] text-white/20 tracking-widest uppercase">v1.0 · Radiofarmacia</p>
        </div>

        <!-- Form side -->
        <div class="mx-auto w-full max-w-md animate-slide-up lg:mx-0 lg:max-w-none">
          <slot />
        </div>

      </div>
    </div>
  </body>
</html>
