---
import AlertBell from './AlertBell';

interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;

const today = new Date().toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long' });
const capitalizedDate = today.charAt(0).toUpperCase() + today.slice(1);
---

<header class="relative flex h-14 shrink-0 items-center justify-between border-b border-gray-200/50 bg-white/90 px-6 backdrop-blur-md">

  <!-- Left: breadcrumb + title -->
  <div class="flex items-center gap-3 min-w-0">
    <!-- Page icon accent -->
    <div class="hidden h-1.5 w-1.5 shrink-0 rounded-full bg-radix-500 sm:block"></div>
    <div class="min-w-0">
      <h1 class="font-display text-[17px] font-semibold tracking-tight text-gray-900 truncate">{title}</h1>
      {subtitle && (
        <p class="text-[11px] font-medium leading-tight text-gray-400 truncate">{subtitle}</p>
      )}
    </div>
  </div>

  <!-- Right: date · bell · avatar -->
  <div class="flex items-center gap-4 shrink-0">

    <!-- Date pill -->
    <div class="hidden items-center gap-1.5 rounded-full border border-gray-100 bg-gray-50 px-3 py-1 sm:flex">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
        <line x1="16" y1="2" x2="16" y2="6"/>
        <line x1="8" y1="2" x2="8" y2="6"/>
        <line x1="3" y1="10" x2="21" y2="10"/>
      </svg>
      <span class="text-[11px] font-medium text-gray-500">{capitalizedDate}</span>
    </div>

    <!-- Divider -->
    <div class="h-5 w-px bg-gray-200"></div>

    <!-- Alert bell -->
    <AlertBell client:load />

    <!-- Divider -->
    <div class="h-5 w-px bg-gray-200"></div>

    <!-- Avatar -->
    <div class="flex items-center gap-2">
      <div class="flex h-8 w-8 items-center justify-center rounded-full bg-gradient-to-br from-radix-500 to-radix-700 ring-2 ring-white shadow-sm">
        <span class="font-display text-[11px] font-bold text-white leading-none">Dr</span>
      </div>
    </div>
  </div>
</header>
