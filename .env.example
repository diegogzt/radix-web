# ── Supabase Auth ─────────────────────────────────────────────────────────────
# Solo se usa para autenticación (login/sesión). Los datos ya NO van a Supabase.
# ⚠️  Este valor se hornea en el bundle del cliente en tiempo de build.
#
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Backend API (Spring Boot — api.raddix.pro) ──────────────────────────────────
# Toda la lógica de datos (pacientes, tratamientos, alertas, métricas, etc.)
# pasa por esta API. ⚠️  También se hornea en el bundle del cliente.
#
# Local:       PUBLIC_API_URL=http://localhost:8080
# Producción:  PUBLIC_API_URL=https://api.raddix.pro
#
PUBLIC_API_URL=https://api.raddix.pro
